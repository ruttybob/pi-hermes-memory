  "repository": {
    "type": "git",
    "url": "https://github.com/ruttybob/pi-self-memory"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@types/node": "^25.8.0",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typebox": "^1.1.33",
    "typescript": "^6.0.3"
  }
